generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum BookCategory {
  PARAGRAF
  DENEME
  KONU
}

// ─── City & District (Türkiye il/ilçe) ─────────────────────────────────────

model City {
  id        String     @id @default(uuid())
  name      String
  districts District[]
  users     User[]

  @@map("cities")
}

model District {
  id     String @id @default(uuid())
  name   String
  cityId String @map("city_id")

  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)
  users  User[]

  @@index([cityId])
  @@map("districts")
}

// ─── User ───────────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  role       Role
  adSoyad    String   @map("ad_soyad")
  cityId     String?  @map("city_id")
  districtId String?  @map("district_id")
  okul       String?

  city     City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  district District? @relation(fields: [districtId], references: [id], onDelete: SetNull)

  // Teacher owns classrooms
  classrooms        Classroom[]
  // Student belongs to classrooms
  classroomStudents ClassroomStudent[]

  results          Result[]
  analytics        Analytics[]
  outcomeAnalytics OutcomeAnalytics[]
  studentAnswers   StudentAnswer[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([role])
  @@index([cityId])
  @@index([districtId])
  @@map("users")
}

// ─── Classroom ───────────────────────────────────────────────────────────────

model Classroom {
  id        String @id @default(uuid())
  name      String
  code      String @unique
  teacherId String @map("teacher_id")

  teacher  User               @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  students ClassroomStudent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([teacherId])
  @@map("classrooms")
}

// ─── ClassroomStudent ────────────────────────────────────────────────────────

model ClassroomStudent {
  id          String @id @default(uuid())
  classroomId String @map("classroom_id")
  studentId   String @map("student_id")

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([classroomId, studentId])
  @@index([studentId])
  @@map("classroom_students")
}

// ─── Book ───────────────────────────────────────────────────────────────────

model Book {
  id          String       @id @default(uuid())
  title       String
  description String       @default("")
  imageUrl    String?      @map("image_url")
  category    BookCategory

  sections         Section[]
  learningOutcomes LearningOutcome[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("books")
}

// ─── Section ────────────────────────────────────────────────────────────────

model Section {
  id          String @id @default(uuid())
  title       String
  description String @default("")
  orderIndex  Int    @default(0) @map("order_index")
  bookId      String @map("book_id")

  book      Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  tests     Test[]
  analytics Analytics[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([bookId])
  @@map("sections")
}

// ─── Test ───────────────────────────────────────────────────────────────────

model Test {
  id          String @id @default(uuid())
  title       String
  description String @default("")
  level       Int    @default(1) // 1-8
  timeLimit   Int    @default(0) @map("time_limit") // seconds
  sectionId   String @map("section_id")

  section   Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questions Question[]
  results   Result[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sectionId])
  @@index([level])
  @@map("tests")
}

// ─── Question ───────────────────────────────────────────────────────────────

model Question {
  id                 String  @id @default(uuid())
  text               String  @default("")
  optionA            String  @default("A") @map("option_a")
  optionB            String  @default("B") @map("option_b")
  optionC            String  @default("C") @map("option_c")
  optionD            String  @default("D") @map("option_d")
  optionE            String  @default("E") @map("option_e")
  correctAnswerIndex Int     @map("correct_answer_index") // 0-4 (A-E)
  explanation        String  @default("")
  videoUrl           String? @map("video_url")
  orderIndex         Int     @default(0) @map("order_index")
  testId             String  @map("test_id")
  learningOutcomeId  String? @map("learning_outcome_id")

  test             Test              @relation(fields: [testId], references: [id], onDelete: Cascade)
  learningOutcome  LearningOutcome?  @relation(fields: [learningOutcomeId], references: [id], onDelete: SetNull)
  answers          Answer[]
  studentAnswers   StudentAnswer[]
  questionOutcomes QuestionOutcome[]

  @@index([testId])
  @@map("questions")
}

// ─── Answer ─────────────────────────────────────────────────────────────────

model Answer {
  id            String  @id @default(uuid())
  resultId      String  @map("result_id")
  questionId    String  @map("question_id")
  selectedIndex Int?    @map("selected_index") // 0-4 (A-E), null = boş
  isCorrect     Boolean @default(false) @map("is_correct")

  result   Result   @relation(fields: [resultId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([resultId, questionId])
  @@index([questionId])
  @@map("answers")
}

// ─── Result ─────────────────────────────────────────────────────────────────

model Result {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  testId     String    @map("test_id")
  score      Float     @default(0)
  totalTime  Int       @default(0) @map("total_time") // seconds
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  test    Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers Answer[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([testId])
  @@map("results")
}

// ─── Analytics ──────────────────────────────────────────────────────────────

model Analytics {
  id               String @id @default(uuid())
  userId           String @map("user_id")
  sectionId        String @map("section_id")

  totalTests       Int   @default(0) @map("total_tests")
  totalQuestions   Int   @default(0) @map("total_questions")
  correctAnswers   Int   @default(0) @map("correct_answers")
  incorrectAnswers Int   @default(0) @map("incorrect_answers")
  averageScore     Float @default(0) @map("average_score")
  bestScore        Float @default(0) @map("best_score")
  totalTime        Int   @default(0) @map("total_time") // seconds
  accuracy         Float @default(0)
  lastAttemptAt    DateTime? @map("last_attempt_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, sectionId])
  @@index([userId])
  @@map("analytics")
}

// ─── OutcomeAnalytics (per user per learning outcome) ───────────────────────

model OutcomeAnalytics {
  id                String @id @default(uuid())
  userId            String @map("user_id")
  learningOutcomeId String @map("learning_outcome_id")

  totalQuestions    Int   @default(0) @map("total_questions")
  correctAnswers    Int   @default(0) @map("correct_answers")
  incorrectAnswers  Int   @default(0) @map("incorrect_answers")
  accuracy          Float @default(0)
  lastAttemptAt     DateTime? @map("last_attempt_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningOutcome LearningOutcome @relation(fields: [learningOutcomeId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, learningOutcomeId])
  @@index([userId])
  @@index([learningOutcomeId])
  @@map("outcome_analytics")
}

// ─── StudentAnswer ──────────────────────────────────────────────────────────

model StudentAnswer {
  id            String  @id @default(uuid())
  userId        String  @map("user_id")
  questionId    String  @map("question_id")
  selectedIndex Int     @map("selected_index") // 0-4 (A-E)
  isCorrect     Boolean @default(false) @map("is_correct")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, questionId])
  @@index([userId])
  @@index([questionId])
  @@map("student_answers")
}

// ─── QuestionOutcome (many-to-many bridge) ──────────────────────────────────

model QuestionOutcome {
  id                String @id @default(uuid())
  questionId        String @map("question_id")
  learningOutcomeId String @map("learning_outcome_id")

  question        Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  learningOutcome LearningOutcome @relation(fields: [learningOutcomeId], references: [id], onDelete: Cascade)

  @@unique([questionId, learningOutcomeId])
  @@index([learningOutcomeId])
  @@map("question_outcomes")
}

// ─── Supporting ─────────────────────────────────────────────────────────────

model LearningOutcome {
  id          String  @id @default(uuid())
  code        String
  name        String
  description String  @default("")
  category    String
  bookId      String? @map("book_id")

  book              Book?              @relation(fields: [bookId], references: [id], onDelete: SetNull)
  questions         Question[]
  questionOutcomes  QuestionOutcome[]
  outcomeAnalytics  OutcomeAnalytics[]

  @@unique([bookId, code])
  @@map("learning_outcomes")
}
